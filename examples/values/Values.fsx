// .NET has several built-in value types.
// Here are a few basic examples.

// Strings, which can be concatenated with +.
printfn "%s" ("go" + "lang")

// Integers and floats.
printfn "1+1 = %d" (1+1)
printfn "7.0/3.0 = %f" (7.0/3.0)

// Booleans, with boolean operators as you'd expect.
printfn "%b" (true && false)
printfn "%b" (true || false)
printfn "%b" (not true)
